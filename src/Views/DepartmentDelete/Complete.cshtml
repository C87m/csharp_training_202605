@using src.Presentations.ViewModels
@model DepartmentDeleteViewModel;
@{
        ViewData["Title"] = "部署削除(完了)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8 text-center">
            <div class="alert alert-success" role="alert">
                部署情報の削除が完了しました。
            </div>
            <table class="table table-hover">
                <tbody>
                    @*削除した部署を表示する*@
                    <tr>
                        <td class="fw-bold">削除した部署</td>
                        <td>@Html.DisplayFor(m => m.Name)</td>
                    </tr>
                </tbody>
            </table>
            @*入力画面に戻る*@
            <a asp-action="Enter" asp-controller="DepartmentDelete" class="btn btn-primary mt-3">
                続けて削除する
            </a>
            @*メニューに戻る*@
            <a asp-action="Index" asp-controller="Home" class="btn btn-secondary mt-3 ms-2">
                メニューに戻る
            </a>
        </div>
    </div>
</div>