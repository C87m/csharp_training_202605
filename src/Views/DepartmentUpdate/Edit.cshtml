@* クラスの名前空間を指定する(C#と同じ) *@
@using src.Presentations.ViewModels
@* View が受け取るデータ型（ViewModel）を宣言asp-for はこの型のプロパティと結びつける *@
@model DepartmentUpdateViewModel;
@{
    ViewData["Title"] = "部署更新";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<h3 class="text-center mt-4">変更した部署情報を入力してください</h3>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-6"> 
            @* 送信先はControllerのConfirm()、POSTは入力値を送信する*@
            <form asp-action="Confirm" asp-controller="DepartmentUpdate" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="BeforeName" />
                <div class="mb-3">
                    @* Tag Helperがname属性やid属性を自動生成 Model Bindingに必要なHTMLが作成される*@
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    @*バリデーション(ModelState)エラーを表示する*@
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="text-center">
                    <button type="submit"
                        formaction="@Url.Action("Confirm", "DepartmentUpdate")"
                        formmethod="post"
                        class="btn btn-primary">完了</button>
                    <button type="submit"
                        formaction="@Url.Action("Enter", "DepartmentUpdate")"
                        formmethod="get"
                        class="btn btn-secondary">部署選択に戻る</button>
                </div>
            </form>
        </div>
    </div>
</div>