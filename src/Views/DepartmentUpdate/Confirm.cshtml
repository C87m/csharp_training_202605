@using src.Presentations.ViewModels
@model DepartmentUpdateViewModel;
@{
    ViewData["Title"] = "部署更新(確認)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8">
            <table class="table table-hover">
                <tbody>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.BeforeName)</td>
                        <td>@Html.DisplayFor(m => m.BeforeName)</td>
                    </tr>
                    <tr>
                        @*DepartmentUpdateViewModelのNameプロパティの値を表示する*@
                        <td class="fw-bold">変更後の部署名</td>
                        <td>@Html.DisplayFor(m => m.Name)</td>
                    </tr>
                </tbody>
            </table>    

            <form>
                @*POSTリクエスト(Update/Back)に値を渡すためにhidden属性を使う*@
                @*これがないと、次の画面で値が消えてしまう*@
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Name" />
                <input type="hidden" asp-for="BeforeName" />
                @*formaction/formmethod ボタンごとに送信先を変える*@
                @*同じフォーム内で[登録]と[戻る]を分岐できる*@
                <div class="text-center mt-4">
                    <button type="submit"
                        formaction="@Url.Action("Update", "DepartmentUpdate")"
                        formmethod="post"
                        class="btn btn-primary">更新</button>
                    <button type="submit"
                        formaction="@Url.Action("Back", "DepartmentUpdate")"
                        formmethod="post"
                        class="btn btn-secondary">戻る</button>
                </div>
            </form>
        </div>
    </div>
</div>