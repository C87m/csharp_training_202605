@* クラスの名前空間を指定する(C#と同じ) *@
@using src.Presentations.ViewModels
@* View が受け取るデータ型（ViewModel）を宣言asp-for はこの型のプロパティと結びつける *@
@model EmployeeDeleteViewModel;
@{
    ViewData["Title"] = "削除社員選択";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-6"> 
            <form asp-controller="EmployeeDelete" asp-action="Confirm" method="post">
                @*部署一覧をプルダウンで表示*@
                <select asp-for="Id" asp-items="Model.Employees" class="form-control"></select>
                </select> 
                @* [選択]ボタン *@
                <br/>
                <div class="d-flex justify-content-center">
                    <button type="submit">選択</button>
                </div>
            </form>
        </div>
    </div>
</div>