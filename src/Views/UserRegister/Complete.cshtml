@using src.Presentations.ViewModels
@model UserRegisterViewModel;
@{
        ViewData["Title"] = "ユーザー登録";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8 text-center">
            <div class="alert alert-success" role="alert">
                ユーザー情報の登録が完了しました。
            </div>
            <table class="table table-hover">
                <tbody>
                    @*登録した部署を表示する*@
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.Id)</td>
                        <td class="fw-bold">@Html.DisplayFor(m => m.Id)</td>
                    </tr>
                    <tr>
                        <td>@Html.DisplayFor(m => m.Id)</td>
                        <td type="password">******</td>
                    </tr>
                </tbody>
            </table>
            @*入力画面に戻る*@
            <a asp-action="Login" asp-controller="UserLogin" class="btn btn-primary mt-3">
                ログインする
            </a>
            @*メニューに戻る*@
            <a asp-action="Enter" asp-controller="Management" class="btn btn-secondary mt-3 ms-2">
                メニューに戻る
            </a>
        </div>
    </div>
</div>